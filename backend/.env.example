# Required
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# LLM Provider: "gemini" (default) or "openai"
LLM_PROVIDER=gemini

# Model names (optional overrides)
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o

# Paths (optional — defaults to project root)
# DOCUMENTS_DIR=./documents
# CHROMA_DIR=./embeddings/chroma

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# RAG settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=6
